# MongoDB connection (required for data persistence)
# Use MongoDB Atlas (free tier) or local MongoDB
# Example: mongodb+srv://user:pass@cluster.mongodb.net/jengo
# Local: mongodb://localhost:27017/jengo
MONGODB_URI=

# JWT secret for auth tokens
JWT_SECRET=your-secret-key

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:5173

# Optional: Skip email verification explicitly
# If false, verification is enforced only when SMTP_HOST/SMTP_USER/SMTP_PASS are all set.
SKIP_EMAIL_VERIFICATION=false

# Optional: SMTP for sending verification emails (required to enforce email verification)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
